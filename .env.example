DATABASE_URL=sqlite:///./music_mvp.db
USE_MOCK_COLLECTOR=true

# SoundCloud — https://developers.soundcloud.com
SOUNDCLOUD_CLIENT_ID=your_soundcloud_client_id
SOUNDCLOUD_OAUTH_TOKEN=your_soundcloud_oauth_token

# Spotify — https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8000/sync/spotify/callback

# YouTube — https://console.cloud.google.com (OAuth 2.0 Web Client)
YOUTUBE_CLIENT_ID=your_google_client_id
YOUTUBE_CLIENT_SECRET=your_google_client_secret
YOUTUBE_REDIRECT_URI=http://127.0.0.1:8000/sync/youtube/callback

# Auto-download
MUZPA_SESS=your_muzpa_session_cookie
DEEZER_ARL=your_deezer_arl_cookie
DOWNLOAD_DIR=/path/to/your/music/folder

# Download options
DOWNLOAD_FULL_EPS=false
ORGANIZE_BY_LIKE_DATE=false

# Deduplication thresholds
DEDUP_STRONG_MATCH_SCORE=90.0
DEDUP_WEAK_MATCH_SCORE=75.0
