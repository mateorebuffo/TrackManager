# Railway provee DATABASE_URL automáticamente al agregar el plugin de Postgres
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Generá uno con: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=cambia-esto-por-un-valor-aleatorio-seguro

USE_MOCK_COLLECTOR=false

# SoundCloud — https://developers.soundcloud.com
SOUNDCLOUD_CLIENT_ID=your_soundcloud_client_id
SOUNDCLOUD_OAUTH_TOKEN=your_soundcloud_oauth_token

# Spotify — https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret
SPOTIFY_REDIRECT_URI=https://tu-app.railway.app/sync/spotify/callback

# YouTube — https://console.cloud.google.com (OAuth 2.0 Web Client)
YOUTUBE_CLIENT_ID=your_google_client_id
YOUTUBE_CLIENT_SECRET=your_google_client_secret
YOUTUBE_REDIRECT_URI=https://tu-app.railway.app/sync/youtube/callback

# Deduplication thresholds
DEDUP_STRONG_MATCH_SCORE=90.0
DEDUP_WEAK_MATCH_SCORE=75.0
